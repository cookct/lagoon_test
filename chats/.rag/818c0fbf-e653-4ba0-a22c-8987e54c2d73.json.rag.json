ons...\n\n*His antenna spins in anxious circles*\n\n...How much was in there?", "embedding": [-0.03300803154706955, 0.06429489701986313, -0.03154178336262703, -0.02036202698945999, 0.06469433754682541, -0.029080940410494804, 0.1838122308254242, -0.02138621173799038, 0.047325655817985535, -0.050174444913864136, 0.04384932294487953, 0.0255722776055336, 0.060621097683906555, 0.009367194026708603, -0.0445915088057518, -0.04051865637302399, 0.04882217198610306, -0.06338196992874146, -0.04989225044846535, 0.0989767462015152, -0.05788019299507141, -0.03011597879230976, 0.08874806016683578, -0.03414792940020561, -0.058998752385377884, 0.09359986335039139, 0.019923901185393333, -0.12230277806520462, -0.1349526345729828, -0.06840567290782928, -0.02917487919330597, 0.07004672288894653, 0.025740433484315872, -0.0642831027507782, 0.05232200771570206, 0.06305164843797684, 0.022610317915678024, 0.092157281935215, 0.015789031982421875, -0.050258588045835495, -0.05192270874977112, -0.005501581355929375, 0.017519518733024597, 0.029288150370121002, -0.027102330699563026, 0.04059165343642235, -0.01339601632207632, -0.027430418878793716, 0.06520486623048782, -0.03773682564496994, -0.06693240255117416, 0.04294878989458084, 0.01839377172291279, 0.02431313320994377, -0.0235516969114542, 0.033031314611434937, 0.18796367943286896, 0.02528030052781105, -0.034844785928726196, -0.002462906064465642, 0.06171729043126106, 0.005287786480039358, -0.027281615883111954, 0.052939265966415405, 0.005458244122564793, 0.017274240031838417, -0.02816767431795597, -0.02688583731651306, 0.02696145325899124, 0.09258478134870529, 0.11817058175802231, -0.016886547207832336, -0.058804675936698914, 0.005430090241134167, 0.039862584322690964, 0.01834162138402462, 0.014909826219081879, -0.0813596323132515, 0.023984787985682487, 0.02331504411995411, -0.08677604794502258, -0.02123895101249218, -0.026755675673484802, 0.016268042847514153, -0.03820877894759178, -0.00941968709230423, -0.04804794862866402, -0.012309675104